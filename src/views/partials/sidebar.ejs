<div id="sidebar">
    <nav>
        <a href="">Logo</a>
        <a href="/home">Home</a>
        <a href="/users">Users</a>
        <a href="/profile">Profile</a>
        <button onclick="openCreatePost()">Create</button>
        <!-- Create Post Modal -->
        <div id="createPostModal" class="modal hidden" >
            <div class="createPost-modal-content">
                <div class="modal-header">
                    <button onclick="closeModals()">Close</button>
                    <h2>Create Post</h2>
                </div>
                <form action="/create" method="POST" class="createPostForm">
                    <div class="createLabelDiv">
                        <label for="content"><%= currentUser.name %></label>
                        <textarea name="content" id="content" placeholder="What's Going On?"></textarea>
                    </div>

                    <button type="submit">Post</button>
                </form>
                <%- include('../partials/errors'); %>
            </div>
        </div>
        <!---->
        <form action="/logout" method="POST">
            <button type="submit">Logout</button>
        </form>
    </nav>
</div>

<script>
    const createPostModal = document.querySelector("#createPostModal");

    function closeModals() {
        createPostModal.classList.add("hidden");
    }

    function openCreatePost() {
        closeModals();
        createPostModal.classList.remove("hidden");
    }
</script>